# .env

# ─────────────────────────────────────────────────────────────────
# CE FICHIER = valeurs par défaut pour TOUS les environnements
# À surcharger dans .env.local (jamais commité sur Git)
# ─────────────────────────────────────────────────────────────────

###> symfony/framework-bundle ###

# Environnement actuel : dev | test | prod
APP_ENV=dev

# Clé secrète utilisée pour sécuriser les sessions, tokens CSRF, etc.
# Générer une vraie valeur : php bin/console secrets:generate-keys
APP_SECRET=6baa7d8037baee4427c78033657418a5eca674e166888a91199470f9f52e3aa0

# Dossier partagé entre déploiements (cache, uploads persistants...)
# Utile en PROD, peut être ignoré en dev local
APP_SHARE_DIR=var/share

###< symfony/framework-bundle ###


###> symfony/routing ###

# URI de base utilisée pour générer des URLs dans les commandes CLI
# (ex: php bin/console debug:router) ou les emails
# En prod, remplacer par votre vrai domaine : https://www.monsite.fr
DEFAULT_URI=http://localhost

###< symfony/routing ###


###> doctrine/doctrine-bundle ###

# Connexion à la base de données
# Structure : mysql://utilisateur:motdepasse@hote:port/nom_bdd?serverVersion=...
# ⚠️ Toujours préciser serverVersion pour éviter des erreurs Doctrine
DATABASE_URL="mysql://root:@127.0.0.1:3306/cartes_postales?serverVersion=10.4.32-MariaDB&charset=utf8mb4"

###< doctrine/doctrine-bundle ###


###> symfony/messenger ###

# Transport utilisé pour les messages asynchrones (emails en queue, tâches de fond...)
# doctrine://default = stockage des messages en base de données ← simple, pas de Redis/RabbitMQ nécessaire
# Alternatives si besoin plus tard :
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages  ← RabbitMQ
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages                 ← Redis
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

###< symfony/messenger ###


###> symfony/mailer ###

# Configuration de l'envoi d'emails
# null://null = aucun email envoyé (parfait pour le dev, évite les envois accidentels)
# En prod, remplacer par ex: smtp://user:pass@smtp.mailtrap.io:587
MAILER_DSN=null://null

###< symfony/mailer ###
