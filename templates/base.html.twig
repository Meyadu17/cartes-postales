<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Cartes Postales{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Felipa&display=swap" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}

</head>
<body>

<nav class="navbar navbar-expand-lg navbar-vintage">
  <div class="container-fluid">

    <a class="navbar-brand" href="{{ path('app_home') }}">🗺️</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>


    <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">

            <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Régions
            </a>
            <ul class="dropdown-menu">
                {% for region in regions_menu %}
                    <li>
                        <a class="dropdown-item" href="/region/{{ region.id }}">
                            {{ region.nom }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="#">Mes cartes postales</a>
            </li>
        </ul>
        <ul class="navbar-nav  mb-2 mb-lg-0">
            <li class="nav-item">
                <a class="nav-link active" aria-current="page" href="{{ path('app_mon_espace') }}">Mon espace</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" aria-current="page" href="#">Wekogril</a>
            </li>
        </ul>
    </div>
  </div>
</nav>

<div class="container mt-4">
    {% block body %}{% endblock %}
</div>

</body>
</html>
