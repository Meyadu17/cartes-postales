{% extends 'base.html.twig' %}

{% block title %}Mon Espace{% endblock %}

{% block body %}


<div class="container mt-4">
    
    {# ===== BOUTON NOUVELLE CARTE POSTALE ===== #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Mon Espace</h1>
        <a href="#" class="btn btn-vintage">
            <i class="bi bi-plus-lg"></i> Nouvelle carte postale
        </a>
    </div>

    {# ===== ONGLETS ===== #}
    <ul class="nav nav-tabs mb-3" id="monEspaceTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="regions-tab" data-bs-toggle="tab" 
                    data-bs-target="#regions" type="button">
                Régions
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="departements-tab" data-bs-toggle="tab" 
                    data-bs-target="#departements" type="button">
                Départements
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="villes-tab" data-bs-toggle="tab" 
                    data-bs-target="#villes" type="button">
                Villes
            </button>
        </li>
    </ul>

    {# ===== CONTENU ONGLETS ===== #}
    <div class="tab-content" id="monEspaceTabContent">

        {# RÉGIONS #}
        <div class="tab-pane fade show active" id="regions" role="tabpanel">
            
            <table class="table table-hover" id="tableRegions">
                <thead>
                    <tr><th>Code</th>
                        <th>Nom</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        {# DÉPARTEMENTS #}
        <div class="tab-pane fade" id="departements" role="tabpanel">
            <table class="table table-hover" id="tableDepartements">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Nom</th>
                        <th>Région</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        {# VILLES #}
        <div class="tab-pane fade" id="villes" role="tabpanel">
            <table class="table table-hover" id="tableVilles">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Département</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
</div>

<!-- ------------------------------------------------------- -->
<!-- -------------------- modale Région -------------------- -->
<!-- ------------------------------------------------------- -->
{% include 'components/_modal_form.html.twig' with {
    modal_id: 'modalNouvelleRegion',
    modal_title: 'Nouvelle région',
    form: form_region
} %}

<!-- ---------------------------------------------------------- -->
<!-- ------------------- modale Département ------------------- -->
<!-- ---------------------------------------------------------- -->
{% include 'components/_modal_form.html.twig' with {
    modal_id: 'modalNouveauDepartement',
    modal_title: 'Nouveau Département',
    form: form_departement
} %}

<!-- ------------------------------------------------------ -->
<!-- -------------------- modale Ville -------------------- -->
<!-- ------------------------------------------------------ -->
{% include 'components/_modal_form.html.twig' with {
    modal_id: 'modalNouvelleVille',
    modal_title: 'Nouvelle Ville',
    form: form_ville
} %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function() {

            console.log('jQuery prêt');
            console.log('modales trouvées :', $('#modalNouvelleRegion').length, $('#modalNouveauDepartement').length, $('#modalNouvelleVille').length);
            console.log('formulaires trouvés :', $('#modalNouvelleRegion form').length);

            // =====================
            // RÉGIONS
            // =====================
            const tableRegions = $('#tableRegions').DataTable({
                ajax: {
                    url: '{{ path("app_data_regions") }}',
                    dataSrc: ''
                },
                columns: [
                    { data: 'code', width: '15%' },
                    { data: 'nom', width: '70%' },
                    {
                        data: 'id',
                        orderable: false,
                        width: '15%',
                        className: 'text-end',
                        render: function(id) {
                            return `<button class="btn btn-sm btn-action-edit"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-action-delete"><i class="bi bi-trash"></i></button>`;
                        }
                    }
                ],
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json' },
                initComplete: function() {
                    const wrapper = $('#tableRegions_wrapper');
                    const length = wrapper.find('.dataTables_length').detach();
                    const filter = wrapper.find('.dataTables_filter').detach();

                    const toolbar = $('<div class="dt-custom-toolbar"></div>');
                    toolbar.append(length);
                    toolbar.append(filter);
                    toolbar.append('<a href="#" class="btn btn-sm btn-vintage" data-bs-toggle="modal" data-bs-target="#modalNouvelleRegion"><i class="bi bi-plus-lg"></i> Nouvelle région</a>');

                    wrapper.prepend(toolbar);
                }
            });

            // =====================
            // DÉPARTEMENTS
            // =====================
            const tableDepartements = $('#tableDepartements').DataTable({
                ajax: {
                    url: '{{ path("app_data_departements") }}',
                    dataSrc: ''
                },
                columns: [
                    { data: 'code', width: '10%' },
                    { data: 'nom', width: '40%' },
                    { data: 'region', width: '35%' },
                    {
                        data: 'id',
                        orderable: false,
                        width: '15%',
                        className: 'text-end',
                        render: function(id) {
                            return `<button class="btn btn-sm btn-action-edit"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-action-delete"><i class="bi bi-trash"></i></button>`;
                        }
                    }
                ],
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json' },
                initComplete: function() {
                    const wrapper = $('#tableDepartements_wrapper');
                    const length = wrapper.find('.dataTables_length').detach();
                    const filter = wrapper.find('.dataTables_filter').detach();

                    const toolbar = $('<div class="dt-custom-toolbar"></div>');
                    toolbar.append(length);
                    toolbar.append(filter);
                    toolbar.append('<a href="#" class="btn btn-sm btn-vintage" data-bs-toggle="modal" data-bs-target="#modalNouveauDepartement"><i class="bi bi-plus-lg"></i> Nouveau département</a>');

                    wrapper.prepend(toolbar);
                }
            });

            // =====================
            // VILLES
            // =====================
            const tableVilles = $('#tableVilles').DataTable({
                ajax: {
                    url: '{{ path("app_data_villes") }}',
                    dataSrc: ''
                },
                columns: [
                    { data: 'nom', width: '45%' },
                    { data: 'departement', width: '40%' },
                    {
                        data: 'id',
                        orderable: false,
                        width: '15%',
                        className: 'text-end',
                        render: function(id) {
                            return `<button class="btn btn-sm btn-action-edit"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-action-delete"><i class="bi bi-trash"></i></button>`;
                        }
                    }
                ],
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json' },
                initComplete: function() {
                    const wrapper = $('#tableVilles_wrapper');
                    const length = wrapper.find('.dataTables_length').detach();
                    const filter = wrapper.find('.dataTables_filter').detach();

                    const toolbar = $('<div class="dt-custom-toolbar"></div>');
                    toolbar.append(length);
                    toolbar.append(filter);
                    toolbar.append('<a href="#" class="btn btn-sm btn-vintage" data-bs-toggle="modal" data-bs-target="#modalNouvelleVille"><i class="bi bi-plus-lg"></i> Nouvelle ville</a>');

                    wrapper.prepend(toolbar);
                }
            });

            // =====================
            // SOUMISSION FORMULAIRES
            // =====================

            // Région
            $('#modalNouvelleRegion_form').on('submit', function(e) {
                console.log('🛑 submit région intercepté');
                e.preventDefault();
                $.ajax({
                    url: '{{ path("app_region_new") }}',
                    method: 'POST',
                    data: $(this).serialize(),
                    success: function() {
                        $('#modalNouvelleRegion').modal('hide');
                        $('body').removeClass('modal-open');
                        $('.modal-backdrop').remove();
                        $('#modalNouvelleRegion_form')[0].reset();
                        tableRegions.ajax.reload();
                    },
                    error: function(xhr) {
                        console.log(xhr.responseText);
                        alert('Erreur lors de la création.');
                    }
                });
            });

            // Département
            $('#modalNouveauDepartement_form').on('submit', function(e) {
                console.log('🛑 submit département intercepté');
                e.preventDefault();
                $.ajax({
                    url: '{{ path("app_departement_new") }}',
                    method: 'POST',
                    data: $(this).serialize(),
                    success: function() {
                        $('#modalNouveauDepartement').modal('hide');
                        $('body').removeClass('modal-open');
                        $('.modal-backdrop').remove();
                        $('#modalNouveauDepartement_form')[0].reset();
                        tableDepartements.ajax.reload();
                    },
                    error: function(xhr) {
                        console.log(xhr.responseText);
                        alert('Erreur lors de la création.');
                    }
                });
            });

            // Ville
            $('#modalNouvelleVille_form').on('submit', function(e) {
                console.log('🛑 submit ville intercepté');
                e.preventDefault();
                $.ajax({
                    url: '{{ path("app_ville_new") }}',
                    method: 'POST',
                    data: $(this).serialize(),
                    success: function() {
                        $('#modalNouvelleVille').modal('hide');
                        $('body').removeClass('modal-open');
                        $('.modal-backdrop').remove();
                        $('#modalNouvelleVille_form')[0].reset();
                        tableVilles.ajax.reload();
                    },
                    error: function(xhr) {
                        console.log(xhr.responseText);
                        alert('Erreur lors de la création.');
                    }
                });
            });


        });
    </script>
{% endblock %}
