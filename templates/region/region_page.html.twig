{# templates/region/region_page.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ region.nom }}{% endblock %}

{% block body %}
<div class="container py-4">

    {# En-tête région #}
    <div class="mb-4">
        <h1>{{ region.nom }}</h1>
        {% if region.description %}
            <p class="lead text-muted">{{ region.description }}</p>
        {% endif %}
    </div>

    {# Liste des départements #}
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        {% for departement in region.departements %}
        <div class="col">
            <div class="card h-100 shadow-sm" style="max-width: 250px;">
                <div class="row g-0 h-100">
                    {# Logo à gauche #}
                    <div class="col-md-5 d-flex align-items-center p-3">
                        <img src="{{ departement.logoNom ? asset(departement.logoPath) : asset('images/icons/departement_default.jpg') }}"
                             alt="Logo du département {{ departement.nom }}"
                             class="img-fluid rounded-start"
                             style="max-height: 80px; object-fit: contain;"
                        >
                    </div>

                    {# Texte à droite #}
                    <div class="col-md-7 d-flex align-items-center">
                        <div class="card-body text-center w-100">
                            <h6 class="card-title mb-1">{{ departement.nom }}</h6>
                            <span class="badge bg-secondary">{{ departement.code }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
            <p class="text-muted">Aucun département pour cette région.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
