{# postcard_new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Nouvelle carte postale{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Ajouter une carte postale</h5>
        </div>

        {{ form_start(form) }}
            {% if not form.vars.valid and form.vars.submitted %}
                <div class="alert alert-danger mx-3 mt-3">
                    Veuillez corriger les erreurs ci-dessous.
                </div>
            {% endif %}

            <div class="card-body">
                <div class="row g-3">

                    {# Champs hidden #}
                    {{ form_widget(form.orientation) }}
                    {{ form_widget(form.imageBase64) }}

                    {# Upload image + Cropper #}
                    <div class="col-12">
                        <label class="form-label fw-semibold">Image de la carte postale</label>

                        <input type="file" id="postcard-file-input" accept="image/*" class="form-control mb-3">

                        {# Boutons orientation — visibles après upload #}
                        <div id="orientation-buttons" class="d-none mb-3 d-flex gap-3">
                            <button type="button" id="btn-portrait" class="btn btn-outline-secondary">
                                <div style="width:40px;height:60px;border:2px solid currentColor;margin:auto"></div>
                                Portrait (2:3)
                            </button>
                            <button type="button" id="btn-landscape" class="btn btn-outline-secondary">
                                <div style="width:60px;height:40px;border:2px solid currentColor;margin:auto"></div>
                                Paysage (3:2)
                            </button>
                        </div>

                        {# Zone cropper #}
                        <div id="cropper-wrapper" class="d-none mb-3">
                            <img id="postcard-cropper-image" src="" alt="Aperçu" style="max-width:100%">
                        </div>

                        {# Aperçu cropé #}
                        <div id="preview-wrapper" class="d-none">
                            <p class="text-muted small">Aperçu :</p>
                            <div id="cropper-preview" style="width:150px;height:150px;overflow:hidden"></div>
                        </div>
                    </div>

                    {# Titre #}
                    <div class="col-12">
                        <div class="form-floating">
                            {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Titre'}}) }}
                            {{ form_label(form.titre) }}
                            {{ form_errors(form.titre) }}
                        </div>
                    </div>

                    {# Description #}
                    <div class="col-12">
                        <div class="form-floating">
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Description', 'style': 'height: 120px'}}) }}
                            {{ form_label(form.description) }}
                            {{ form_errors(form.description) }}
                        </div>
                    </div>

                    {# Année #}
                    <div class="col-md-4">
                        <div class="form-floating">
                            {{ form_widget(form.annee, {'attr': {'class': 'form-control', 'placeholder': 'Année'}}) }}
                            {{ form_label(form.annee) }}
                            {{ form_errors(form.annee) }}
                        </div>
                    </div>

                    {# Département #}
                    <div class="col-md-4">
                        {{ form_label(form.departement, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.departement, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.departement) }}
                    </div>

                    {# Ville #}
                    <div class="col-md-4 ville-wrapper">
                        {{ form_label(form.ville, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.ville, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.ville) }}
                    </div>

                    {# Carrousel #}
                    <div class="col-12">
                        <div class="form-check form-switch">
                            {{ form_widget(form.enCaroussel, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(form.enCaroussel, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            {{ form_errors(form.enCaroussel) }}
                        </div>
                    </div>

                </div>
            </div>

            <div class="card-footer d-flex justify-content-end gap-2">
                <a href="{{ path('app_postcard_data') }}" class="btn btn-secondary">
                    Annuler
                </a>
                <button type="submit" name="action" value="save_and_new" class="btn btn-outline-primary">
                    Enregistrer et créer à nouveau
                </button>
                <button type="submit" name="action" value="save" class="btn btn-primary">
                    Enregistrer
                </button>
            </div>
        {{ form_end(form) }}

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('postcard-create') }}
{% endblock %}
