{% extends 'base.html.twig' %}

{% block title %}Nouvelle carte postale{% endblock %}

{% block body %}
<div class="container py-4">

    {# BREADCRUMB #}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_postcard_data') }}">Cartes postales</a>
            </li>
            <li class="breadcrumb-item active">Nouvelle carte postale</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Ajouter une carte postale</h5>
        </div>

        {{ form_start(form) }}
        <div class="card-body">
            <div class="row g-3">

                {# Titre #}
                <div class="col-12">
                    <div class="form-floating">
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Titre'}}) }}
                        {{ form_label(form.titre) }}
                        {{ form_errors(form.titre) }}
                    </div>
                </div>

                {# Description #}
                <div class="col-12">
                    <div class="form-floating">
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Description', 'style': 'height: 120px'}}) }}
                        {{ form_label(form.description) }}
                        {{ form_errors(form.description) }}
                    </div>
                </div>

                {# Année #}
                <div class="col-md-4">
                    <div class="form-floating">
                        {{ form_widget(form.annee, {'attr': {'class': 'form-control', 'placeholder': 'Année'}}) }}
                        {{ form_label(form.annee) }}
                        {{ form_errors(form.annee) }}
                    </div>
                </div>

                {# Orientation #}
                <div class="col-md-4">
                    <div class="form-floating">
                        {{ form_widget(form.orientation, {'attr': {'class': 'form-select'}}) }}
                        {{ form_label(form.orientation) }}
                        {{ form_errors(form.orientation) }}
                    </div>
                </div>

                {# Département #}
                <div class="col-md-4">
                    <div class="form-floating">
                        {{ form_widget(form.departement, {'attr': {'class': 'form-select'}}) }}
                        {{ form_label(form.departement) }}
                        {{ form_errors(form.departement) }}
                    </div>
                </div>

                {# Ville #}
                <div class="col-md-4 ville-wrapper">
                    <div class="form-floating">
                        {{ form_widget(form.ville, {'attr': {'class': 'form-select'}}) }}
                        {{ form_label(form.ville) }}
                        {{ form_errors(form.ville) }}
                    </div>
                </div>

                {# Carrousel #}
                <div class="col-12">
                    <div class="form-check form-switch">
                        {{ form_widget(form.enCaroussel, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.enCaroussel, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        {{ form_errors(form.enCaroussel) }}
                    </div>
                </div>

            </div>
        </div>

        <div class="card-footer d-flex justify-content-end gap-2">
            <a href="{{ path('app_postcard_data') }}" class="btn btn-secondary">
                Annuler
            </a>
            <button type="submit" name="action" value="save_and_new" class="btn btn-outline-primary">
                Enregistrer et créer à nouveau
            </button>
            <button type="submit" name="action" value="save" class="btn btn-primary">
                Enregistrer
            </button>
        </div>
        {{ form_end(form) }}

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('postcard-create') }}
{% endblock %}
